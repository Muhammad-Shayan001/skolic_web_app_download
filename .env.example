# Environment Configuration (Example)
# Copy this file to .env and update with actual values

# QR Code API Endpoint (optional - currently using public API)
VITE_QR_API_ENDPOINT=https://api.qrserver.com/v1/create-qr-code

# APK Download URL (can be customized for different environments)
VITE_APK_DOWNLOAD_URL=./app-release.apk

# Site Configuration
VITE_SITE_NAME=Skolic
VITE_SITE_DESCRIPTION=School Management System

# Analytics (optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Production Flag
VITE_PRODUCTION=false
